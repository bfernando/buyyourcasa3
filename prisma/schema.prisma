generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Step 1 — captured immediately on first action
  address   String
  source    String  @default("desktop") // "desktop" | "mobile" | "voice-en" | "voice-es" | "sms-vapi"
  channel   String?
  step      Int     @default(1) // highest step reached
  completed Boolean @default(false)

  // Step 2 — contact info
  phone     String?
  firstName String?
  lastName  String?
  email     String?

  // Step 3/4 — property details
  condition String?
  timeline  String?
  reason    String?

  // Voice agent (Vapi) call artifacts — nullable; only populated when the
  // lead originated from the browser voice agent (source starts with "voice-").
  callId          String? @unique
  callDurationSec Int?
  recordingUrl    String?
  transcript      Json?

  // Inbound SMS. The provider message ID is the Vapi Chat ID (or immutable
  // tool-call ID fallback), which is stable across webhook retries. The first
  // valid SMS creates the lead even when the seller never finishes intake.
  smsProvider               String?
  providerMessageId         String?   @unique
  inboundMessage            String?
  firstInboundAt            DateTime?
  lastInboundAt             DateTime?
  smsOptedOutAt             DateTime?
  smsEmailAlertClaimedAt    DateTime?
  smsInternalAlertClaimedAt DateTime?
  attribution               Json?

  @@map("leads")
}
